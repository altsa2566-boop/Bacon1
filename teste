if not game:IsLoaded() then game.Loaded:Wait() end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- anti duplicate
if PlayerGui:FindFirstChild("AsylumLoader") then
    PlayerGui.AsylumLoader:Destroy()
end

-- basic integrity table (anti tamper light)
local integrity = {
    started = tick(),
    stage = 0
}

local function safeHttp(url)
    local ok, res = pcall(function()
        return game:HttpGet(url)
    end)
    if not ok then return nil end
    return res
end

local function safeRun(code)
    if type(code) ~= "string" then return end
    local ok, err = pcall(function()
        return loadstring(code)()
    end)
    if not ok then
        warn("Execution failed:", err)
    end
end

-- simple environment noise (anti-basic logger confusion)
local function noise()
    local t = {}
    for i = 1, 5 do
        t[i] = math.random() * tick()
    end
    return t
end

noise()

-- UI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AsylumLoader"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = PlayerGui

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 380, 0, 260)
Frame.Position = UDim2.new(0.5, -190, 0.5, -130)
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
Frame.BorderSizePixel = 0
Frame.Parent = ScreenGui

Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 14)

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 70)
Title.BackgroundTransparency = 1
Title.Text = "ASYLUM AIM HUB"
Title.TextColor3 = Color3.fromRGB(255,255,255)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 24
Title.Parent = Frame

local function button(txt, y, color, callback)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -40, 0, 55)
    b.Position = UDim2.new(0, 20, 0, y)
    b.BackgroundColor3 = color
    b.Text = txt
    b.TextColor3 = Color3.fromRGB(255,255,255)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 18
    b.Parent = Frame

    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 12)

    b.MouseButton1Click:Connect(function()
        integrity.stage += 1

        b.Text = "Loading..."
        task.wait(0.1)

        callback()
    end)
end

-- loader wrapper (slightly obfuscated flow)
local function loadModule(url)
    local data = safeHttp(url)
    if not data then return end

    -- fake delay to break simple timing-based analysis
    for _ = 1, 3 do
        task.wait()
    end

    safeRun(data)
end

button("Load Mobile Version", 90, Color3.fromRGB(0,170,255), function()
    ScreenGui:Destroy()
    loadModule("https://pastebin.com/raw/xNUdEcgd")
end)

button("Load PC Version", 155, Color3.fromRGB(138,43,226), function()
    ScreenGui:Destroy()
    loadModule("https://pastebin.com/raw/yDbTMWXq")
end)

-- simple integrity watcher (very light anti-tamper)
task.spawn(function()
    while task.wait(1) do
        if integrity.stage > 10 then
            ScreenGui:Destroy()
            break
        end
    end
end)
